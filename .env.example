# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/quizchain"

# AI APIs (at least one required for AI quiz generation)
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# OAuth — Google
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — Discord
# Create at: https://discord.com/developers/applications
# Redirects: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

NODE_ENV="development"

# Web3 (optional - for blockchain features)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
NEXT_PUBLIC_ROOTSTOCK_RPC_URL="https://public-node.rsk.co"
ROOTSTOCK_PRIVATE_KEY=""
