generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  avatar        String?
  walletAddress String?   @unique
  role          UserRole  @default(PLAYER)

  accounts      Account[]
  sessions      Session[]
  quizzesHosted  Quiz[]
  participations QuizParticipant[]
  achievements   Achievement[]

  totalScore    Int @default(0)
  quizzesWon    Int @default(0)
  quizzesPlayed Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Quiz {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    QuizCategory
  difficulty  Difficulty   @default(MEDIUM)
  mode        QuizMode     @default(AI_GENERATED)
  status      QuizStatus   @default(DRAFT)
  coverImage  String?

  questions Quiz_Question[]
  rooms     Room[]

  hostId String
  host   User   @relation(fields: [hostId], references: [id])

  entryFee        Float?
  prizePool       Float?
  contractAddress String?
  chainId         Int?

  prizeType        String    @default("NONE")
  prizeCurrency    String?
  prizeDescription String?
  scheduledAt      DateTime?

  timesPlayed Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quiz_Question {
  id           String   @id @default(cuid())
  text         String
  options      String[]
  correctIndex Int
  explanation  String?
  points       Int      @default(1000)
  timeLimit    Int      @default(30)
  order        Int

  quizId  String
  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers Answer[]
}

model Room {
  id              String     @id @default(cuid())
  code            String     @unique
  status          RoomStatus @default(WAITING)
  currentQuestion Int        @default(0)
  maxPlayers      Int        @default(100)
  isPublic        Boolean    @default(true)

  quizId       String
  quiz         Quiz              @relation(fields: [quizId], references: [id])
  participants QuizParticipant[]

  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
}

model QuizParticipant {
  id           String @id @default(cuid())
  nickname     String
  avatar       String?
  score        Int    @default(0)
  totalTime    Int    @default(0)
  streakCount  Int    @default(0)
  rank         Int?
  isConnected  Boolean @default(true)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  answers Answer[]

  walletAddress String?

  joinedAt DateTime @default(now())
}

model Answer {
  id            String  @id @default(cuid())
  selectedIndex Int
  isCorrect     Boolean
  timeSpent     Int
  pointsEarned  Int     @default(0)
  streakBonus   Int     @default(0)

  questionId    String
  question      Quiz_Question   @relation(fields: [questionId], references: [id])
  participantId String
  participant   QuizParticipant @relation(fields: [participantId], references: [id])

  answeredAt DateTime @default(now())
}

model Achievement {
  id        String          @id @default(cuid())
  type      AchievementType
  title     String
  metadata  Json?
  txHash    String?
  nftTokenId String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  earnedAt DateTime @default(now())
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  status      TournamentStatus @default(UPCOMING)
  prizePool   Float
  entryFee    Float            @default(0)
  maxTeams    Int              @default(16)
  startDate   DateTime
  endDate     DateTime?

  onChainId   String?
  txHash      String?

  createdAt DateTime @default(now())
}

enum UserRole {
  PLAYER
  HOST
  ADMIN
}

enum QuizCategory {
  BLOCKCHAIN
  ROOTSTOCK
  BITCOIN
  BIOLOGY
  SPORTS
  HISTORY
  MOVIES
  RELIGION
  CUSTOM
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizMode {
  AI_GENERATED
  MANUAL
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RoomStatus {
  WAITING
  ACTIVE
  PAUSED
  ENDED
}

enum AchievementType {
  FIRST_WIN
  SPEED_DEMON
  PERFECT_SCORE
  STREAK_5
  STREAK_10
  COMMUNITY_STAR
  BLOCKCHAIN_EXPERT
  TOURNAMENT_WINNER
  EARLY_BIRD
  TOP_3
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  ENDED
  CANCELLED
}
